{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "iluhaAnime",
  "version": "1.0.0",
  "identifier": "com.александр.iluhaAnime",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "iluhaAnime",
        "minWidth": 860,
        "width": 860,
        "minHeight": 600,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost https://s4.anilist.co data:; media-src 'self' asset: http://asset.localhost blob: data: file:",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**",
          "$RESOURCE/**",
          "$APPDATA/**",
          "$APPLOCALDATA/**",
          "$TEMP/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
